# ============================================================
# Forsterite DEPLETION — one graph per cell
# (primary Mg source; key mineral in Iceland olivine basalt)
# ============================================================

USER_GRAPH 16
    -heading  Time_days  Forsterite_mol
    -axis_titles  "Time (days)"  "Forsterite remaining (mol) -- Cell 1"
    -axis_scale x_axis 0 365
    -start
    5  if CELL_NO <> 1 then end
    10 graph_x TOTAL_TIME / 86400
    20 graph_y KIN("Forsterite")
    -end

