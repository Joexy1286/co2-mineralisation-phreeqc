USER_GRAPH 21
    -heading  Time_days  Kaolinite_mol
    -axis_titles  "Time (days)"  "Kaolinite precipitated (mol) -- Cell 1"
    -axis_scale x_axis 0 365
    -start
    5  if CELL_NO <> 1 then end
    10 graph_x TOTAL_TIME / 86400
    20 graph_y EQUI("Kaolinite")
    -end

USER_GRAPH 22
    -heading  Time_days  Kaolinite_mol
    -axis_titles  "Time (days)"  "Kaolinite precipitated (mol) -- Cell 5"
    -axis_scale x_axis 0 365
    -start
    5  if CELL_NO <> 5 then end
