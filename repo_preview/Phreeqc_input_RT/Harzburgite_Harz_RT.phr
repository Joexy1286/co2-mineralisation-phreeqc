# ============================================================
# SPATIAL PROFILES - pH and Mg vs cell number (all timesteps)
# Mg replaces Ca as the primary spatial tracer (Harzburgite is Mg-dominated)
# ============================================================

USER_GRAPH 24
    -heading  Cell  pH_spatial
    -axis_titles  "Cell number"  "pH (all timesteps)"
    -axis_scale x_axis 0 11
    -axis_scale y_axis 3 11
    -start
    10 graph_x CELL_NO
    20 graph_y -LA("H+")
    -end

USER_GRAPH 25
    -heading  Cell  Mg_mM_spatial
    -axis_titles  "Cell number"  "Mg (mmol/L) -- all timesteps"
    -axis_scale x_axis 0 11
    -start
    10 graph_x CELL_NO
    20 graph_y TOT("Mg") * 1000
    -end

# ============================================================
# SATURATION INDICES at cell 5 midpoint monitor
# Magnesite added: key Mg-carbonate; critical for CO2 mineralisation
# assessment in ultramafic context
# ============================================================

USER_GRAPH 26
    -heading  Time_days  SI_Calcite  SI_Kaolinite  SI_Siderite  SI_Dolomite  SI_Magnesite  SI_Goethite  zero
    -axis_titles  "Time (days)"  "Saturation Index -- Cell 5"
    -axis_scale x_axis 0 365
    -start
    5  if CELL_NO <> 5 then end
    10 graph_x TOTAL_TIME / 86400
    20 graph_y SI("Calcite")
    30 graph_y SI("Kaolinite")
    40 graph_y SI("Siderite")
    50 graph_y SI("Dolomite")
    55 graph_y SI("Magnesite")
    57 graph_y SI("Goethite")
    60 graph_y 0
    -end

END
