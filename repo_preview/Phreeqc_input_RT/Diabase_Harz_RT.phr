# ============================================================
# Anorthite DEPLETION — one graph per cell
# (primary Ca-releasing phase in Diabase)
# ============================================================

USER_GRAPH 16
    -heading  Time_days  Anorthite_mol
    -axis_titles  "Time (days)"  "Anorthite remaining (mol) -- Cell 1"
    -axis_scale x_axis 0 365
    -start
    5  if CELL_NO <> 1 then end
    10 graph_x TOTAL_TIME / 86400
    20 graph_y KIN("Anorthite")
    -end

USER_GRAPH 17
    -heading  Time_days  Anorthite_mol
    -axis_titles  "Time (days)"  "Anorthite remaining (mol) -- Cell 3"
    -axis_scale x_axis 0 365
